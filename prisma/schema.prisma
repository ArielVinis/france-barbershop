generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DEV
  OWNER
  MANAGER
  BARBER
  CLIENT
}

enum BookingStatus {
  CONFIRMED
  IN_PROGRESS
  FINISHED
  CANCELLED
  NO_SHOW
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  CANCELLED
}

model User {
  id            String       @id
  name          String
  email         String?      @unique
  emailVerified Boolean
  role          Role         @default(CLIENT)
  image         String?
  phone         String?      @unique
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  owner         Barbershop[] @relation("OwnerBarbershops")

  // TODO: Add ratings for barbers and barbershops
  ratings Rating[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
  @@map("verification")
}

model Booking {
  id            String            @id @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId     String
  service       BarbershopService @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  date          DateTime
  status        BookingStatus     @default(CONFIRMED)
  observations  String?
  paymentMethod PaymentMethod?
  paymentStatus PaymentStatus     @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Barbershop
model Barbershop {
  id          String               @id @default(uuid())
  name        String
  slug        String               @unique
  address     String
  phones      String[]
  description String
  imageUrl    String
  owners      User[]               @relation("OwnerBarbershops")
  services    BarbershopService[]
  ratings       Rating[]
  schedules     BarbershopSchedule[]
  breaks        BarbershopBreak[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BarbershopService {
  id              String     @id @default(uuid())
  name            String
  description     String
  imageUrl        String
  price           Decimal    @db.Decimal(10, 2)
  durationMinutes Int
  barbershopId    String
  barbershop      Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  bookings        Booking[]
}

model BarbershopSchedule {
  id           String     @id @default(uuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  dayOfWeek    Int // 0 = Domingo, 1 = Segunda, 2 = Terça, 3 = Quarta, 4 = Quinta, 5 = Sexta, 6 = Sábado
  startTime    String // "08:00" formato HH:mm
  endTime      String // "18:00" formato HH:mm
  isActive     Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barbershopId, dayOfWeek])
}

model BarbershopBreak {
  id           String     @id @default(uuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  dayOfWeek    Int // 0 = Domingo, …, 6 = Sábado
  startTime    String // "12:00" formato HH:mm
  endTime      String // "13:00" formato HH:mm

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Rating
model Rating {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  stars        Int
  comment      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
